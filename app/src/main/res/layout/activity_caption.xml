<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Full-screen photo background -->
    <ImageView
        android:id="@+id/ivPhoto"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:contentDescription="@string/photo_preview_desc"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Title overlay: top-left, semi-transparent dark background -->
    <LinearLayout
        android:id="@+id/titleContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#A0000000"
        android:padding="4dp"
        android:layout_margin="8dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/btnTitleMic"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_mic"
            android:contentDescription="@string/mic_title_desc"
            android:tint="@android:color/white" />

        <EditText
            android:id="@+id/etTitle"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:hint="@string/hint_title"
            android:textSize="14sp"
            android:textColor="@android:color/white"
            android:textColorHint="#80FFFFFF"
            android:singleLine="true"
            android:inputType="text"
            android:background="@null"
            android:paddingStart="6dp"
            android:paddingEnd="4dp" />

    </LinearLayout>

    <!-- Save button: top-right -->
    <Button
        android:id="@+id/btnSave"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_save"
        android:backgroundTint="#CC1976D2"
        android:textColor="@android:color/white"
        android:layout_margin="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- GPS toggle + live coordinates: bottom-right, above description bar -->
    <LinearLayout
        android:id="@+id/gpsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="6dp"
        app:layout_constraintBottom_toTopOf="@id/descContainer"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Coordinates text – hidden until GPS is active and location is known -->
        <TextView
            android:id="@+id/tvGpsCoords"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="9sp"
            android:background="#A0000000"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:layout_marginEnd="4dp"
            android:visibility="gone" />

        <!-- GPS toggle button – always visible, dimmed when inactive -->
        <ImageButton
            android:id="@+id/btnGpsToggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_gps"
            android:contentDescription="@string/gps_toggle_desc"
            android:tint="@android:color/white"
            android:alpha="0.45" />

    </LinearLayout>

    <!-- Description overlay: bottom, full width, multiline (grows upward) -->
    <LinearLayout
        android:id="@+id/descContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#A0000000"
        android:padding="4dp"
        android:gravity="bottom"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/etDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/hint_description"
            android:textSize="9sp"
            android:textColor="@android:color/white"
            android:textColorHint="#80FFFFFF"
            android:inputType="textMultiLine"
            android:minLines="1"
            android:maxLines="6"
            android:background="@null"
            android:paddingStart="6dp"
            android:paddingEnd="4dp"
            android:gravity="bottom|start" />

        <ImageButton
            android:id="@+id/btnDescMic"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="bottom"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_mic"
            android:contentDescription="@string/mic_desc_desc"
            android:tint="@android:color/white" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
